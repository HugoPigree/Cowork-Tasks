# Leave empty to use same-origin `/api` (Vite dev proxy -> Django :8000).
# Use the API *origin* only — do NOT append /api (all paths already start with /api/).
#   OK:   VITE_API_BASE=http://localhost:8000
#   OK:   VITE_API_BASE=https://api.example.com
#   BAD:  VITE_API_BASE=http://localhost:8000/api   (would duplicate /api; we fix this in code, but prefer the correct form)
VITE_API_BASE=
