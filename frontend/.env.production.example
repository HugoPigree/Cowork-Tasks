# Build-time: copy to `.env.production` before `npm run build`.
# Set the public API origin (no trailing slash, no extra /api suffix).

# Example: API at https://api.example.com → requests go to https://api.example.com/api/...
VITE_API_BASE=https://api.example.com

# Same host as the SPA (nginx proxies /api to Gunicorn):
# VITE_API_BASE=
