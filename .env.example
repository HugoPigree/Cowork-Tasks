# Copy to `.env` and adjust values. Never commit real secrets.

# Django — REQUIRED in production: generate with:
#   openssl rand -base64 48
SECRET_KEY=replace-me-generate-with-openssl-rand-base64-48
DEBUG=False
# Comma-separated hostnames (add your public domain in production)
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL (docker-compose maps these to the `db` service)
DB_NAME=taskmanager
DB_USER=taskmanager
DB_PASSWORD=change-me-db-password
DB_HOST=localhost
DB_PORT=5432

# --- Production / HTTPS (behind reverse proxy) ---
# Trust X-Forwarded-Proto / Host from Traefik, Caddy, nginx, load balancers
DJANGO_TRUST_X_FORWARDED_PROTO=true
# Redirect HTTP→HTTPS inside Django (usually false if the proxy already enforces TLS)
DJANGO_SECURE_SSL_REDIRECT=false
# HSTS (set e.g. 31536000 after you are sure HTTPS works everywhere)
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false
# Secure session/CSRF cookies (enable when users hit the site over HTTPS)
DJANGO_SESSION_COOKIE_SECURE=false
# Comma-separated origins for Django admin CSRF, e.g. https://app.example.com
CSRF_TRUSTED_ORIGINS=
# Serve /media/* via Gunicorn (true = OK for small VPS; false if nginx serves /media or you use S3)
DJANGO_SERVE_MEDIA=true

# API tuning (optional)
API_PAGE_SIZE=10
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS — exact origins of the SPA (scheme + host + port), comma-separated
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
